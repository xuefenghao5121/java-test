+     * @param targetScale 用户指定的目标 scale
+     * @param roundingMode 舍入模式
+     * @return 正确的除法结果
+     */
+    private static BigDecimal createDivideResult(long value, int scaleDiff,
+                                                   int targetScale, int roundingMode) {
+        // 正确的 intermediateScale 计算：targetScale - scaleDiff
+        // 这适用于所有情况（scaleDiff 正、负、零）
+        int intermediateScale = targetScale - scaleDiff;
+        BigDecimal result = valueOf(value, intermediateScale);
+        if (intermediateScale != targetScale) {
+            result = result.setScale(targetScale, roundingMode);
+        }
+        return result;
