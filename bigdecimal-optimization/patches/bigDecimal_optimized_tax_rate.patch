+    /**
+     * Optimized check for multiplication that supports long-tail distributions.
+     * Adds support for large amounts × small tax rates (e.g., $100M × 0.08).
+     *
+     * @param x the first multiplier
+     * @param y the second multiplier
+     * @return true if fast path can be used
+     */
+    private static boolean isSmallMultiplyOptimized(long x, long y) {
+        long absX = Math.abs(x);
+        long absY = Math.abs(y);
+
+        // Fast path 1: both numbers small (< 10^9)
+        if (absX < 1_000_000_000L && absY < 1_000_000_000L) {
+            return true;
+        }
+
+        // Fast path 2: one very small (tax rate < 1000), other can be up to 10^13
+        // Supports large transaction × tax rate scenario
+        if (absX < 1_000L && absY < 10_000_000_000_000L) {
+            return true;
+        }
+        if (absY < 1_000L && absX < 10_000_000_000_000L) {
+            return true;
+        }
+
+        return false;
+    }
