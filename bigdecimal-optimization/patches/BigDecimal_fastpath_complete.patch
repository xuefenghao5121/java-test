+/**
+ * Fast check if char array matches financial format
+ *
+ * Financial format pattern:
+ * - Optional sign (+/-)
+ * - 1-12 digits (integer part)
+ * - Optional decimal point
+ * - If decimal present, exactly 2 digits (currency) or 4 digits (percentage)
+ *
+ * @return scale value if matches financial pattern, -1 otherwise
+ */
+private static int checkFinancialFastPath(char[] in, int offset, int len) {
+    if (len < 1 || len > 18) return -1; // Fast reject
+
+    int pos = offset;
+    int end = offset + len;
+
+    // Check optional sign
+    if (in[pos] == '+' || in[pos] == '-') {
+        pos++;
+        if (pos >= end) return -1;
+    }
+
+    int digitCount = 0;
+    int decimalPos = -1;
+
+    // Scan digits and decimal point
+    for (; pos < end; pos++) {
+        char c = in[pos];
+        if (c >= '0' && c <= '9') {
+            digitCount++;
+            if (digitCount > 12) return -1; // Too many digits
+        } else if (c == '.') {
+            if (decimalPos != -1) return -1; // Multiple decimal points
+            decimalPos = digitCount;
+        } else {
+            return -1; // Invalid character
+        }
+    }
+
+    if (digitCount == 0) return -1;
+
+    // Determine scale
+    if (decimalPos == -1) {
+        return 0; // No decimal point
+    }
+
+    int fractionDigits = digitCount - decimalPos;
+    // Fast path: 2 digits (currency) or 4 digits (percentage)
+    if (fractionDigits == 2) {
+        return 2;
+    } else if (fractionDigits == 4) {
+        return 4;
+    }
+
+    return -1;
+}
+
+/**
+ * Fast parse financial format string
+ */
+private static BigDecimal parseFinancialFastPath(char[] in, int offset, int len,
+        int scale, MathContext mc) {
+    int pos = offset;
+    int end = offset + len;
+    boolean isneg = false;
+
+    // Handle sign
+    if (in[pos] == '+' || in[pos] == '-') {
+        isneg = (in[pos] == '-');
+        pos++;
+    }
+
+    // Parse digits (ignore decimal point)
+    long value = 0;
+    for (; pos < end; pos++) {
+        char c = in[pos];
+        if (c >= '0' && c <= '9') {
+            value = value * 10 + (c - '0');
+        }
+    }
+
+    if (isneg) value = -value;
+
+    BigDecimal result = valueOf(value, scale);
+    return mc.precision == 0 ? result : result.round(mc);
+}
